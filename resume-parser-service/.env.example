# Maximum accepted upload size, in megabytes.
MAX_UPLOAD_SIZE_MB=10

# Comma-separated list of origins allowed by CORS.
ALLOWED_ORIGINS=http://localhost:3000

# A PDF with fewer total extracted characters than this is flagged as
# possibly requiring OCR (this service does not perform OCR itself).
OCR_MIN_TOTAL_CHARACTERS=200

# A page with fewer extracted characters than this counts as "low text"
# when deciding whether most pages look image-based.
OCR_MIN_CHARACTERS_PER_PAGE=40

# PDFs with more pages than this are flagged as unusually long for a resume.
HIGH_PAGE_COUNT_WARNING_THRESHOLD=12
